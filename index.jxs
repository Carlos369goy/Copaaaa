            destaque: false
          });

          // Simulação em Direto
          useEffect(() => {
            const timer = setInterval(() => {
              setMatches(prevMatches => {
                let isUpcomingStarted = false;
                return prevMatches.map(match => {
                  if (match.status === 'UPCOMING' && Math.random() < 0.15 && !isUpcomingStarted) {
                    isUpcomingStarted = true;
                    setNotifications(prev => [
                      { id: Math.random().toString(), text: `🚨 COMEÇOU! ${match.home} vs ${match.away} está em direto!`, timestamp: "Agora" },
                      ...prev.slice(0, 4)
                    ]);
                    return { ...match, status: 'LIVE', minute: 1, homeScore: 0, awayScore: 0, events: ["1' Apito Inicial!"] };
                  }

                  if (match.status === 'LIVE') {
                    const nextMinute = match.minute + 2;
                    if (nextMinute >= 90) {
                      setNotifications(prev => [
                        { id: Math.random().toString(), text: `🏁 FIM DO ENCONTRO: ${match.home} ${match.homeScore} - ${match.awayScore} ${match.away}`, timestamp: "Terminado" },
                        ...prev.slice(0, 4)
                      ]);
                      return { ...match, minute: 90, status: 'FINISHED' };
                    }

                    const goloChance = Math.random();
                    let newHomeScore = match.homeScore;
                    let newAwayScore = match.awayScore;
                    let newEvents = [...match.events];

                    if (goloChance < 0.15) {
                      const isHome = Math.random() > 0.45;
                      const scoringTeam = isHome ? match.home : match.away;
                      isHome ? newHomeScore++ : newAwayScore++;

                      const teamPlayers = players.filter(p => p.selecao === scoringTeam);
                      let scorerName = "Avançado";

                      if (teamPlayers.length > 0) {
                        const attackerList = teamPlayers.filter(p => p.posicao === 'Avançado' || p.posicao === 'Médio');
                        const selectedScorer = attackerList.length > 0 
                          ? attackerList[Math.floor(Math.random() * attackerList.length)] 
                          : teamPlayers[Math.floor(Math.random() * teamPlayers.length)];

                        scorerName = selectedScorer.nomeCurto;

                        setPlayers(current => current.map(p => {
                          if (p.id === selectedScorer.id) {
                            const newGols = p.estatisticas.golos + 1;
                            const newRating = Math.min(10, parseFloat((p.estatisticas.notaMedia + 0.15).toFixed(2)));
                            const newVal = p.valorMercado + 3;

                            setNotifications(prev => [
                              { id: Math.random().toString(), text: `⚽ GOLO! ${p.nomeCurto} marcou! Valor subiu para €${newVal}M e nota para ★ ${newRating}!`, timestamp: "Golo" },
                              ...prev.slice(0, 4)
                            ]);

                            return { ...p, valorMercado: newVal, estatisticas: { ...p.estatisticas, golos: newGols, notaMedia: newRating }, atualizadoRecentemente: true };
                          }
                          return p;
                        }));

                        setTimeout(() => {
                          setPlayers(current => current.map(p => p.id === selectedScorer.id ? { ...p, atualizadoRecentemente: false } : p));
                        }, 6000);
                      }

                      newEvents.push(`${nextMinute}' GOLO da ${scoringTeam}! Marcador: ${scorerName}.`);
                    }

                    return { ...match, minute: nextMinute, homeScore: newHomeScore, awayScore: newAwayScore, events: newEvents.slice(-3) };
                  }
                  return match;
                });
              });
            }, 6000);
            return () => clearInterval(timer);
          }, [players]);

          const countriesList = useMemo(() => ['Todos', ...new Set(players.map(p => p.selecao))], [players]);
          const positionsList = ['Todos', 'Guarda-redes', 'Defesa', 'Médio', 'Avançado'];

          const handleResetFilters = () => {
            setSearchQuery('');
            setSelectedCountry('Todos');
            setSelectedPosition('Todos');
            setSelectedAgeGroup('Todos');
            setSelectedSort('notaMedia_desc');
          };

          const filteredPlayers = useMemo(() => {
            return players
              .filter(player => {
                const matchesSearch = player.nome.toLowerCase().includes(searchQuery.toLowerCase()) || player.nomeCurto.toLowerCase().includes(searchQuery.toLowerCase()) || player.clube.toLowerCase().includes(searchQuery.toLowerCase());
                const matchesCountry = selectedCountry === 'Todos' || player.selecao === selectedCountry;
                const matchesPosition = selectedPosition === 'Todos' || player.posicao === selectedPosition;
                let matchesAge = true;
                if (selectedAgeGroup === 'jovens') matchesAge = player.idade < 23;
                else if (selectedAgeGroup === 'auge') matchesAge = player.idade >= 23 && player.idade <= 30;
                else if (selectedAgeGroup === 'veteranos') matchesAge = player.idade > 30;
                return matchesSearch && matchesCountry && matchesPosition && matchesAge;
              })
              .sort((a, b) => {
                if (selectedSort === 'nome') return a.nomeCurto.localeCompare(b.nomeCurto);
                if (selectedSort === 'idade') return a.idade - b.idade;
                if (selectedSort === 'valorMercado_desc') return b.valorMercado - a.valorMercado;
                if (selectedSort === 'golos_desc') return b.estatisticas.golos - a.estatisticas.golos;
                if (selectedSort === 'notaMedia_desc') return b.estatisticas.notaMedia - a.estatisticas.notaMedia;
                return 0;
              });
          }, [players, searchQuery, selectedCountry, selectedPosition, selectedAgeGroup, selectedSort]);

          const statistics = useMemo(() => {
            const total = players.length;
            if (total === 0) return { total: 0, mediaIdade: 0, mediaNota: 0, valorTotal: 0, maiorGoleador: 'Nenhum' };
            const mediaIdade = (players.reduce((acc, curr) => acc + curr.idade, 0) / total).toFixed(1);
            const mediaNota = (players.reduce((acc, curr) => acc + curr.estatisticas.notaMedia, 0) / total).toFixed(2);
            const valorTotal = players.reduce((acc, curr) => acc + curr.valorMercado, 0);
            const topScorer = [...players].sort((a, b) => b.estatisticas.golos - a.estatisticas.golos)[0];
            return { total, mediaIdade, mediaNota, valorTotal, maiorGoleador: topScorer ? `${topScorer.nomeCurto} (${topScorer.estatisticas.golos} Golos)` : 'Nenhum' };
          }, [players]);

          const handleSavePlayer = (e) => {
            e.preventDefault();
            if (isEditing) {
              setPlayers(prev => prev.map(p => p.id === isEditing ? { ...newPlayer, id: isEditing } : p));
              setIsEditing(null);
            } else {
              setPlayers(prev => [{ ...newPlayer, id: Math.random().toString(), idade: Number(newPlayer.idade), valorMercado: Number(newPlayer.valorMercado), numeroCamisa: Number(newPlayer.numeroCamisa) }, ...prev]);
            }
            setActiveTab('explorador');
          };

          const handleStartEdit = (player) => {
            setNewPlayer(player);
            setIsEditing(player.id);
            setActiveTab('gerenciamento');
          };

          const handleDeletePlayer = (id) => {
            if (window.confirm("Desejas remover este jogador da lista?")) {
              setPlayers(prev => prev.filter(p => p.id !== id));
            }
          };

          return (
            <div className="flex flex-col min-h-screen">
              <header className="bg-slate-950 border-b border-slate-800 sticky top-0 z-30 shadow-lg">
                <div className="max-w-7xl mx-auto px-4 py-3 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-4">
                  <div className="flex items-center gap-3">
                    <div className="bg-gradient-to-tr from-emerald-500 to-yellow-400 p-2.5 rounded-xl text-slate-950 font-bold">COPA</div>
                    <div>
                      <h1 className="text-xl font-bold tracking-tight bg-gradient-to-r from-emerald-400 to-yellow-300 bg-clip-text text-transparent">DATAFUT • COPA 2026</h1>
                      <p className="text-xs text-slate-400">Banco de Dados em Direto • Sincronização Inteligente</p>
                    </div>
                  </div>
                  <nav className="flex gap-1 bg-slate-900 p-1 rounded-xl border border-slate-800 text-xs sm:text-sm">
                    <button onClick={() => setActiveTab('explorador')} className={`px-3 py-1.5 rounded-lg font-medium transition-all ${activeTab === 'explorador' ? 'bg-emerald-500 text-slate-950' : 'text-slate-400 hover:text-slate-200'}`}>Explorador</button>
                    <button onClick={() => setActiveTab('analytics')} className={`px-3 py-1.5 rounded-lg font-medium transition-all ${activeTab === 'analytics' ? 'bg-emerald-500 text-slate-950' : 'text-slate-400 hover:text-slate-200'}`}>Estatísticas</button>
                    <button onClick={() => { setIsEditing(null); setActiveTab('gerenciamento'); }} className={`px-3 py-1.5 rounded-lg font-medium transition-all ${activeTab === 'gerenciamento' ? 'bg-emerald-500 text-slate-950' : 'text-slate-400 hover:text-slate-200'}`}>{isEditing ? 'Editar' : 'Adicionar'}</button>
                    <button onClick={() => setActiveTab('jogos')} className={`px-3 py-1.5 rounded-lg font-medium transition-all relative ${activeTab === 'jogos' ? 'bg-emerald-500 text-slate-950' : 'text-slate-400 hover:text-slate-200'}`}>Ao Vivo <span className="absolute -top-1 -right-1 w-2 h-2 bg-rose-500 rounded-full animate-ping"></span></button>
                  </nav>
                </div>
              </header>

              <div className="bg-slate-950 border-b border-slate-850 px-4 py-2 flex items-center gap-3 overflow-x-auto">
                <span className="bg-rose-500/20 text-rose-400 text-xs font-bold px-2 py-0.5 rounded border border-rose-500/30 animate-pulse">LIVE FEED</span>
                <span className="text-xs text-slate-200 truncate">{notifications[0]?.text || "A aguardar eventos..."}</span>
              </div>

              {/* Métricas rápidas */}
              <div className="bg-slate-950/20 border-b border-slate-800/80 py-4">
                <div className="max-w-7xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-4">
                  <div className="bg-slate-900/60 p-3 rounded-xl border border-slate-800/60 text-center sm:text-left">
                    <p className="text-xs text-slate-400">Atletas Inscritos</p>
                    <p className="text-lg font-bold text-slate-100 mt-1">{statistics.total}</p>
                  </div>
                  <div className="bg-slate-900/60 p-3 rounded-xl border border-slate-800/60 text-center sm:text-left">
                    <p className="text-xs text-slate-400">Idade Média</p>
                    <p className="text-lg font-bold text-slate-100 mt-1">{statistics.mediaIdade} anos</p>
                  </div>
                  <div className="bg-slate-900/60 p-3 rounded-xl border border-slate-800/60 text-center sm:text-left">
                    <p className="text-xs text-slate-400">Nota Média Geral</p>
                    <p className="text-lg font-bold text-slate-100 mt-1">{statistics.mediaNota}</p>
                  </div>
                  <div className="bg-slate-900/60 p-3 rounded-xl border border-slate-800/60 text-center sm:text-left">
                    <p className="text-xs text-slate-400">Valor do Plantel</p>
                    <p className="text-lg font-bold text-slate-100 mt-1">€ {statistics.valorTotal}M</p>
                  </div>
                </div>
              </div>

              <main className="flex-grow max-w-7xl w-full mx-auto px-4 py-6 sm:px-6 lg:px-8">
                {activeTab === 'explorador' && (
                  <div className="flex flex-col lg:flex-row gap-6">
                    <aside className="w-full lg:w-1/4 bg-slate-950/60 border border-slate-800 p-5 rounded-2xl flex flex-col gap-5 h-fit">
                      <div className="flex justify-between items-center border-b border-slate-800 pb-2">
                        <span className="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center gap-1.5"><Icons.SlidersHorizontal /> Filtros</span>
                        <button onClick={handleResetFilters} className="text-xs text-slate-500 hover:text-emerald-400 flex items-center gap-1"><Icons.RotateCcw /> Limpar</button>
                      </div>

                      <div>
                        <label className="block text-xs text-slate-400 mb-1.5 font-medium">Nome do Atleta ou Clube</label>
                        <input type="text" value={searchQuery} onChange={e => setSearchQuery(e.target.value)} placeholder="Pesquisa..." className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-sm text-slate-200 focus:outline-none focus:ring-1 focus:ring-emerald-500" />
                      </div>

                      <div>
                        <label className="block text-xs text-slate-400 mb-1.5 font-medium">Seleção</label>
                        <select value={selectedCountry} onChange={e => setSelectedCountry(e.target.value)} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-sm text-slate-200 focus:outline-none">
                          {countriesList.map(c => <option key={c} value={c}>{c}</option>)}
                        </select>
                      </div>

                      <div>
                        <label className="block text-xs text-slate-400 mb-1.5 font-medium">Posição</label>
                        <select value={selectedPosition} onChange={e => setSelectedPosition(e.target.value)} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-sm text-slate-200 focus:outline-none">
                          {positionsList.map(p => <option key={p} value={p}>{p}</option>)}
                        </select>
                      </div>

                      <div>
                        <label className="block text-xs text-slate-400 mb-1.5 font-medium">Ordenar por</label>
                        <select value={selectedSort} onChange={e => setSelectedSort(e.target.value)} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-sm text-slate-200 focus:outline-none">
                          <option value="notaMedia_desc">Melhor Nota</option>
                          <option value="valorMercado_desc">Valor de Mercado</option>
                          <option value="golos_desc">Mais Golos</option>
                          <option value="nome">Nome Alfabético</option>
                        </select>
                      </div>
                    </aside>

                    <section className="w-full lg:w-3/4">
                      <div className="flex justify-between items-center mb-4 bg-slate-950/40 p-3 rounded-xl border border-slate-800/60">
                        <div>
                          <h2 className="font-bold text-slate-200">Resultados Encontrados ({filteredPlayers.length})</h2>
                        </div>
                        <div className="flex gap-2">
                          <button onClick={() => setViewMode('grid')} className={`p-1.5 rounded ${viewMode === 'grid' ? 'bg-slate-800 text-emerald-400' : 'text-slate-500'}`}><Icons.Grid /></button>
                          <button onClick={() => setViewMode('table')} className={`p-1.5 rounded ${viewMode === 'table' ? 'bg-slate-800 text-emerald-400' : 'text-slate-500'}`}><Icons.List /></button>
                        </div>
                      </div>

                      {viewMode === 'grid' ? (
                        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                          {filteredPlayers.map(player => (
                            <div key={player.id} className={`bg-slate-950/75 rounded-2xl border ${player.atualizadoRecentemente ? 'border-emerald-400 shadow-lg shadow-emerald-400/20' : player.destaque ? 'border-emerald-500/30' : 'border-slate-800'} p-5 flex flex-col justify-between transition-all`}>
                              <div>
                                <div className="flex justify-between items-start mb-4">
                                  <div className="flex gap-3 items-center">
                                    <div className="w-12 h-12 bg-slate-800 rounded-xl flex items-center justify-center font-bold text-slate-300 relative">
                                      {player.nomeCurto.substring(0, 2).toUpperCase()}
                                      <span className="absolute -bottom-1 -right-1 bg-emerald-500 text-slate-950 text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold">{player.numeroCamisa}</span>
                                    </div>
                                    <div>
                                      <h3 className="font-bold text-slate-100">{player.nomeCurto}</h3>
                                      <p className="text-xs text-slate-400">{player.selecao}</p>
                                    </div>
                                  </div>
                                  <span className="text-xs text-slate-500 font-bold uppercase">{player.posicao}</span>
                                </div>

                                <div className="grid grid-cols-2 gap-2 text-xs py-2 border-t border-b border-slate-900 mb-3 text-slate-300">
                                  <div><span className="text-slate-500 block text-[10px]">CLUBE</span>{player.clube}</div>
                                  <div><span className="text-slate-500 block text-[10px]">VALOR</span>€ {player.valorMercado}M</div>
                                  <div><span className="text-slate-500 block text-[10px]">IDADE</span>{player.idade} anos</div>
                                  <div><span className="text-slate-500 block text-[10px]">NOTA</span>★ {player.estatisticas.notaMedia}</div>
                                </div>
                              </div>

                              <div className="flex gap-2 mt-4">
                                <button onClick={() => setSelectedPlayer(player)} className="text-xs bg-slate-800 hover:bg-slate-700 px-3 py-1.5 rounded-lg flex-grow flex items-center justify-center gap-1"><Icons.Info /> Perfil</button>
                                <button onClick={() => handleStartEdit(player)} className="p-1.5 hover:text-blue-400"><Icons.Edit3 /></button>
                                <button onClick={() => handleDeletePlayer(player.id)} className="p-1.5 hover:text-rose-400"><Icons.Trash2 /></button>
                              </div>
                            </div>
                          ))}
                        </div>
                      ) : (
                        <div className="bg-slate-950/60 rounded-2xl border border-slate-800 overflow-x-auto">
                          <table className="w-full text-left min-w-[600px] text-xs">
                            <thead>
                              <tr className="bg-slate-900 text-slate-400 uppercase font-bold border-b border-slate-800">
                                <th className="p-3">Jogador</th>
                                <th className="p-3">Seleção</th>
                                <th className="p-3">Posição</th>
                                <th className="p-3">Clube</th>
                                <th className="p-3 text-center">Golos</th>
                                <th className="p-3 text-right">Valor</th>
                                <th className="p-3 text-center">Nota</th>
                                <th className="p-3 text-right">Ações</th>
                              </tr>
                            </thead>
                            <tbody>
                              {filteredPlayers.map(player => (
                                <tr key={player.id} className="border-b border-slate-900 hover:bg-slate-900/30">
                                  <td className="p-3 font-bold">{player.nomeCurto}</td>
                                  <td className="p-3">{player.selecao}</td>
                                  <td className="p-3">{player.posicao}</td>
                                  <td className="p-3">{player.clube}</td>
                                  <td className="p-3 text-center font-bold">{player.estatisticas.golos}</td>
                                  <td className="p-3 text-right text-emerald-400 font-bold">€{player.valorMercado}M</td>
                                  <td className="p-3 text-center text-yellow-400 font-bold">★ {player.estatisticas.notaMedia}</td>
                                  <td className="p-3 text-right">
                                    <button onClick={() => setSelectedPlayer(player)} className="p-1 hover:text-emerald-400"><Icons.Info /></button>
                                    <button onClick={() => handleStartEdit(player)} className="p-1 hover:text-blue-400"><Icons.Edit3 /></button>
                                    <button onClick={() => handleDeletePlayer(player.id)} className="p-1 hover:text-rose-400"><Icons.Trash2 /></button>
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      )}
                    </section>
                  </div>
                )}

                {activeTab === 'analytics' && (
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div className="bg-slate-950/60 border border-slate-800 p-6 rounded-2xl">
                      <h3 className="font-bold text-sm tracking-wider uppercase mb-4 flex items-center gap-1.5"><Icons.Award /> Média de Notas por Posição</h3>
                      <div className="space-y-4">
                        {['Avançado', 'Médio', 'Defesa', 'Guarda-redes'].map(pos => {
                          const list = players.filter(p => p.posicao === pos);
                          const avg = list.length > 0 ? (list.reduce((acc, c) => acc + c.estatisticas.notaMedia, 0) / list.length).toFixed(2) : "0.00";
                          return (
                            <div key={pos} className="space-y-1">
                              <div className="flex justify-between text-xs"><span className="text-slate-300">{pos}</span><span className="text-yellow-400 font-bold">★ {avg}</span></div>
                              <div className="w-full bg-slate-900 h-2 rounded-full overflow-hidden"><div className="bg-yellow-400 h-full" style={{ width: `${(parseFloat(avg) / 10) * 100}%` }}></div></div>
                            </div>
                          );
                        })}
                      </div>
                    </div>

                    <div className="bg-slate-950/60 border border-slate-800 p-6 rounded-2xl">
                      <h3 className="font-bold text-sm tracking-wider uppercase mb-4 flex items-center gap-1.5"><Icons.Users /> Faixa Demográfica (Idades)</h3>
                      <div className="space-y-4">
                        {[
                          { label: "Jovens Promessas (<23)", count: players.filter(p => p.idade < 23).length },
                          { label: "No Auge (23-30)", count: players.filter(p => p.idade >= 23 && p.idade <= 30).length },
                          { label: "Veteranos (+30)", count: players.filter(p => p.idade > 30).length }
                        ].map(group => {
                          const pct = players.length > 0 ? (group.count / players.length) * 100 : 0;
                          return (
                            <div key={group.label} className="space-y-1">
                              <div className="flex justify-between text-xs"><span className="text-slate-300">{group.label}</span><span className="text-slate-400">{group.count} atletas ({pct.toFixed(0)}%)</span></div>
                              <div className="w-full bg-slate-900 h-2 rounded-full overflow-hidden"><div className="bg-blue-400 h-full" style={{ width: `${pct}%` }}></div></div>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  </div>
                )}

                {activeTab === 'gerenciamento' && (
                  <div className="max-w-2xl mx-auto bg-slate-950/60 border border-slate-800 p-6 rounded-2xl shadow-xl">
                    <h2 className="text-lg font-bold mb-4">{isEditing ? 'Editar Atleta' : 'Adicionar Novo Jogador'}</h2>
                    <form onSubmit={handleSavePlayer} className="space-y-4 text-xs">
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <label className="block text-slate-400 mb-1">Nome Completo</label>
                          <input type="text" required value={newPlayer.nome} onChange={e => setNewPlayer({ ...newPlayer, nome: e.target.value })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                        <div>
                          <label className="block text-slate-400 mb-1">Nome em Campo</label>
                          <input type="text" required value={newPlayer.nomeCurto} onChange={e => setNewPlayer({ ...newPlayer, nomeCurto: e.target.value })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                      </div>

                      <div className="grid grid-cols-3 gap-4">
                        <div>
                          <label className="block text-slate-400 mb-1">Seleção</label>
                          <input type="text" required value={newPlayer.selecao} onChange={e => setNewPlayer({ ...newPlayer, selecao: e.target.value })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                        <div>
                          <label className="block text-slate-400 mb-1">Posição</label>
                          <select value={newPlayer.posicao} onChange={e => setNewPlayer({ ...newPlayer, posicao: e.target.value })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200">
                            <option value="Avançado">Avançado</option>
                            <option value="Médio">Médio</option>
                            <option value="Defesa">Defesa</option>
                            <option value="Guarda-redes">Guarda-redes</option>
                          </select>
                        </div>
                        <div>
                          <label className="block text-slate-400 mb-1">Camisa</label>
                          <input type="number" required value={newPlayer.numeroCamisa} onChange={e => setNewPlayer({ ...newPlayer, numeroCamisa: Number(e.target.value) })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                      </div>

                      <div className="grid grid-cols-3 gap-4">
                        <div>
                          <label className="block text-slate-400 mb-1">Clube</label>
                          <input type="text" required value={newPlayer.clube} onChange={e => setNewPlayer({ ...newPlayer, clube: e.target.value })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                        <div>
                          <label className="block text-slate-400 mb-1">Idade</label>
                          <input type="number" required value={newPlayer.idade} onChange={e => setNewPlayer({ ...newPlayer, idade: Number(e.target.value) })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                        <div>
                          <label className="block text-slate-400 mb-1">Valor (€M)</label>
                          <input type="number" required value={newPlayer.valorMercado} onChange={e => setNewPlayer({ ...newPlayer, valorMercado: Number(e.target.value) })} className="w-full bg-slate-900 border border-slate-800 rounded-xl py-2 px-3 text-slate-200" />
                        </div>
                      </div>

                      <div className="flex justify-end gap-3 pt-4 border-t border-slate-850">
                        <button type="submit" className="px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-bold rounded-xl flex items-center gap-1"><Icons.Check /> Guardar</button>
                      </div>
                    </form>
                  </div>
                )}

                {activeTab === 'jogos' && (
                  <div className="max-w-4xl mx-auto space-y-6">
                    <div className="bg-slate-950/60 border border-slate-800 p-6 rounded-2xl">
                      <h2 className="text-lg font-bold mb-4 flex items-center gap-2 text-rose-400"><span className="w-2 h-2 rounded-full bg-rose-500 animate-ping"></span> Partidas em Direto</h2>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {matches.map(match => (
                          <div key={match.id} className="bg-slate-900/70 border border-slate-850 p-4 rounded-xl flex flex-col justify-between">
                            <div className="flex justify-between items-center text-[10px] text-slate-500 pb-2 border-b border-slate-800 mb-3">
                              <span>{match.stage}</span>
                              <span className={match.status === 'LIVE' ? 'text-rose-500 font-bold' : ''}>{match.status === 'LIVE' ? `${match.minute}' AO VIVO` : match.status}</span>
                            </div>
                            <div className="flex justify-between items-center py-2">
                              <span className="font-bold w-1/3 text-center truncate">{match.home}</span>
                              <span className="text-sm font-bold bg-slate-950 px-2.5 py-1 rounded">{match.homeScore} - {match.awayScore}</span>
                              <span className="font-bold w-1/3 text-center truncate">{match.away}</span>
                            </div>
                            {match.events.length > 0 && (
                              <div className="mt-3 p-2 bg-slate-950/40 rounded text-[9px] font-mono text-slate-400">
                                <ul>{match.events.map((ev, i) => <li key={i}>• {ev}</li>)}</ul>
                              </div>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                )}
              </main>

              {/* MODAL DETALHES JOGADOR */}
              {selectedPlayer && (
                <div className="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
                  <div className="bg-slate-900 border border-slate-850 w-full max-w-md rounded-2xl p-6 relative">
                    <button onClick={() => setSelectedPlayer(null)} className="absolute top-4 right-4 text-slate-400 hover:text-white"><Icons.X /></button>
                    <div className="flex gap-4 items-center mb-6">
                      <div className="w-14 h-14 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center font-extrabold text-xl">{selectedPlayer.nomeCurto.substring(0, 2).toUpperCase()}</div>
                      <div>
                        <h2 className="text-lg font-bold">{selectedPlayer.nomeCurto}</h2>
                        <p className="text-xs text-slate-400">{selectedPlayer.nome}</p>
                        <p className="text-xs text-emerald-400 font-semibold mt-1">{selectedPlayer.selecao}</p>
                      </div>
                    </div>
                    <div className="space-y-4 text-xs">
                      <div className="grid grid-cols-2 gap-4 bg-slate-950/40 p-3 rounded-xl">
                        <div><span className="text-slate-500 block text-[10px]">CLUBE</span>{selectedPlayer.clube}</div>
                        <div><span className="text-slate-500 block text-[10px]">LIGA</span>{selectedPlayer.ligaClube}</div>
                        <div><span className="text-slate-500 block text-[10px]">IDADE</span>{selectedPlayer.idade} anos</div>
                        <div><span className="text-slate-500 block text-[10px]">PÉ PREFERIDO</span>{selectedPlayer.pePreferido}</div>
                      </div>
                      <div className="grid grid-cols-3 gap-2 text-center bg-slate-900 p-2 rounded-xl">
                        <div><span className="text-lg font-bold text-slate-200">{selectedPlayer.estatisticas.golos}</span><p className="text-[10px] text-slate-500 uppercase">Golos</p></div>
                        <div><span className="text-lg font-bold text-slate-200">{selectedPlayer.estatisticas.assistencias}</span><p className="text-[10px] text-slate-500 uppercase">Assists</p></div>
                        <div><span className="text-lg font-bold text-yellow-400">★ {selectedPlayer.estatisticas.notaMedia}</span><p className="text-[10px] text-slate-500 uppercase">Nota</p></div>
                      </div>
                      <div className="pt-4 border-t border-slate-800 text-center"><button onClick={() => setSelectedPlayer(null)} className="bg-emerald-500 text-slate-950 px-6 py-1.5 font-bold rounded-xl hover:bg-emerald-600">Fechar</button></div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        }

        const container = document.getElementById('root');
        const root = ReactDOM.createRoot(container);
        root.render(<App />);
    </script>
</body>
</html>
